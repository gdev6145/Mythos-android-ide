<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1e1e1e">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:background="#252526">

        <ImageButton
            android:id="@+id/btnLogcatBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_revert"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/navigate_up"
            android:tint="#cccccc" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="@string/logcat_title"
            android:textColor="#cccccc"
            android:textSize="15sp"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/spinnerLogLevel"
            android:layout_width="90dp"
            android:layout_height="32dp" />

        <ImageButton
            android:id="@+id/btnLogcatClear"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_delete"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/logcat_clear"
            android:tint="#cccccc" />

        <ImageButton
            android:id="@+id/btnLogcatPause"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_media_pause"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/logcat_pause"
            android:tint="#cccccc" />
    </LinearLayout>

    <EditText
        android:id="@+id/etLogcatFilter"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:hint="@string/logcat_filter_hint"
        android:textSize="13sp"
        android:fontFamily="monospace"
        android:paddingHorizontal="12dp"
        android:background="#333333"
        android:textColor="#d4d4d4"
        android:textColorHint="#666666"
        android:singleLine="true"
        android:inputType="text" />

    <ScrollView
        android:id="@+id/svLogcat"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <TextView
            android:id="@+id/tvLogcatOutput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:fontFamily="monospace"
            android:textSize="11sp"
            android:textColor="#d4d4d4"
            android:lineSpacingExtra="1dp"
            android:textIsSelectable="true" />
    </ScrollView>

</LinearLayout>
